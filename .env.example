# ====================================
# 基础配置
# ====================================
# 应用访问地址
BASE_URL=http://localhost:3000
# 应用端口
PORT=3000
# 监听IP地址（0.0.0.0 表示监听所有网卡）
IP=0.0.0.0

# ====================================
# 主数据库配置
# ====================================
# 数据库类型：mysql | postgres | sqlite
DB_TYPE=mysql
# 数据库地址（Docker环境使用容器名，如 db）
DB_HOST=127.0.0.1
# 数据库端口
DB_PORT=3306
# 数据库用户名
DB_USER=root
# 数据库密码
DB_PASSWORD=your_password_here
# 数据库名称（SQLite时为文件路径）
DB_DATABASE=nest-serve

# PostgreSQL配置示例（当DB_TYPE=postgres时使用）
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your_password_here
# DB_DATABASE=nest-serve

# SQLite配置示例（当DB_TYPE=sqlite时使用）
# DB_TYPE=sqlite
# DB_DATABASE=sqlitedata/nest.db

# ====================================
# 日志数据库配置
# ====================================
# 日志数据库类型：mysql | postgres | sqlite
LOG_DB_TYPE=mysql
# 日志数据库地址
LOG_DB_HOST=127.0.0.1
# 日志数据库端口
LOG_DB_PORT=3306
# 日志数据库用户名
LOG_DB_USER=root
# 日志数据库密码
LOG_DB_PASSWORD=your_password_here
# 日志数据库名称
LOG_DB_DATABASE=nest-serve-log

# ====================================
# Redis缓存配置
# ====================================
# 是否启用Redis（true/false）
REDIS_ENABLED=true
# Redis主机地址（Docker环境使用容器名，如 redis）
REDIS_HOST=127.0.0.1
# Redis端口
REDIS_PORT=6379
# Redis密码（如果有的话）
# REDIS_PASSWORD=
# Redis数据库编号
REDIS_DB=0
# Redis键前缀
REDIS_KEY_PREFIX=nest-serve:
# 是否启用降级机制（Redis不可用时使用NodeCache）
REDIS_FALLBACK_ENABLED=true

# ====================================
# JWT认证配置
# ====================================
# 管理员JWT密钥（生产环境请使用强随机字符串）
JWT_ADMIN_SECRET=your_admin_secret_key_here
# 管理员JWT过期时间（毫秒）3600000 = 1小时
JWT_ADMIN_EXPIRES_IN=3600000
# 管理员JWT刷新令牌过期时间（毫秒）86400000 = 24小时
JWT_ADMIN_REFRESH_EXPIRES_IN=86400000
# Web端JWT密钥（生产环境请使用强随机字符串）
JWT_WEB_SECRET=your_web_secret_key_here
# Web端JWT过期时间（毫秒）3600000 = 1小时
JWT_WEB_EXPIRES_IN=3600000
# Web端JWT刷新令牌过期时间（毫秒）86400000 = 24小时
JWT_WEB_REFRESH_EXPIRES_IN=86400000

# ====================================
# 邮箱配置
# ====================================
# SMTP主机（示例：smtp.qq.com, smtp.gmail.com）
EMAIL_HOST=smtp.qq.com
# SMTP端口（SSL: 465, TLS: 587）
EMAIL_PORT=465
# 是否使用SSL（true/false）
EMAIL_SECURE=true
# SMTP用户名（邮箱地址）
EMAIL_USER=your_email@qq.com
# SMTP密码（或授权码）
EMAIL_PASS=your_email_password_or_auth_code

# ====================================
# CORS配置
# ====================================
# 允许的跨域来源（多个用逗号分隔，生产环境请配置具体域名）
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ====================================
# 文件上传配置
# ====================================
# 文件上传目录
UPLOAD_DIR=./uploads
# 文件大小限制（字节）10485760 = 10MB
UPLOAD_MAX_SIZE=10485760
# 允许的文件类型（多个用逗号分隔）
# 图片格式
#   jpeg -> image/jpeg
#   png  -> image/png
#   gif  -> image/gif
#   webp -> image/webp
#   svg  -> image/svg+xml
#   bmp  -> image/bmp
#   tiff -> image/tiff
#   ico  -> image/x-icon
# 文档格式
#   pdf  -> application/pdf
#   doc  -> application/msword
#   docx -> application/vnd.openxmlformats-officedocument.wordprocessingml.document
#   xls  -> application/vnd.ms-excel
#   xlsx -> application/vnd.openxmlformats-officedocument.spreadsheetml.sheet
#   ppt  -> application/vnd.ms-powerpoint
#   pptx -> application/vnd.openxmlformats-officedocument.presentationml.presentation
#   txt  -> text/plain
#   csv  -> text/csv
# 压缩文件
#   zip  -> application/zip
#   rar  -> application/x-rar-compressed
#   7z   -> application/x-7z-compressed
#   tar  -> application/x-tar
#   gz   -> application/gzip
# 音频格式
#   mp3  -> audio/mpeg
#   wav  -> audio/wav
#   ogg  -> audio/ogg
#   m4a  -> audio/x-m4a
#   aac  -> audio/aac
# 视频格式
#   mp4  -> video/mp4
#   mov  -> video/quicktime
#   avi  -> video/x-msvideo
#   wmv  -> video/x-ms-wmv
#   webm -> video/webm
# 其他格式
#   json -> application/json
#   xml  -> application/xml
#   xml  -> text/xml
#   通用 -> application/octet-stream
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp,image/svg+xml,image/bmp,image/tiff,image/x-icon,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-powerpoint,application/vnd.openxmlformats-officedocument.presentationml.presentation,text/plain,text/csv,application/zip,application/x-rar-compressed,application/x-7z-compressed,application/x-tar,application/gzip,audio/mpeg,audio/wav,audio/ogg,audio/x-m4a,audio/aac,video/mp4,video/quicktime,video/x-msvideo,video/x-ms-wmv,video/webm,application/json,application/xml,text/xml,application/octet-stream

# ====================================
# 其他配置
# ====================================
# 时区
TZ=Asia/Shanghai
# 运行环境：development | production
NODE_ENV=development
# 端口自动递增（端口被占用时自动+1）
PORT_AUTO=false
